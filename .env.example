# LiveKit Cloud
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_SIP_TRUNK_ID=ST_xxxxxxxxxxxx

# STT — Deepgram Nova-3 ($0.0065/min)
DEEPGRAM_API_KEY=your_deepgram_api_key
DEEPGRAM_MODEL=nova-3

# LLM — Groq Llama 3.1 8B (~$0.004/min, ~120ms TTFT)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant

# TTS — Cartesia Sonic (~75ms TTFB)
CARTESIA_API_KEY=your_cartesia_api_key
CARTESIA_VOICE_ID=a0e99841-438c-4a64-b679-ae501e7d6091
CARTESIA_MODEL=sonic-2024-10-19

# Database
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/voice_agent

# SIP provider (Telnyx/Plivo/Twilio — any works)
SIP_PROVIDER_URI=sip.telnyx.com
SIP_AUTH_USERNAME=your_username
SIP_AUTH_PASSWORD=your_password
SIP_FROM_NUMBER=+1xxxxxxxxxx
